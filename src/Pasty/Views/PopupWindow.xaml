<Window x:Class="Pasty.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Pasty.ViewModels"
        xmlns:conv="clr-namespace:Pasty.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="520" Height="460"
        PreviewKeyDown="OnPreviewKeyDown"
        Deactivated="OnDeactivated">

    <Window.Resources>
        <conv:ByteArrayToImageConverter x:Key="BytesToImage"/>
        <conv:BoolToVisibilityInverseConverter x:Key="BoolToVisInverse"/>
    </Window.Resources>

    <Border CornerRadius="10"
            Background="{StaticResource BaseBrush}"
            BorderBrush="{StaticResource Surface1Brush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.6" ShadowDepth="3" Color="#000000"/>
        </Border.Effect>

        <DockPanel Margin="10">

            <!-- Title bar -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Pasty"
                           Foreground="{StaticResource LavenderBrush}"
                           FontSize="13" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding FilteredItems.Count, StringFormat='{}{0} items'}"
                           Foreground="{StaticResource Overlay0Brush}"
                           FontSize="11"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Search box -->
            <Border DockPanel.Dock="Top" CornerRadius="6"
                    Background="{StaticResource Surface0Brush}"
                    Padding="10,8" Margin="0,0,0,8">
                <Grid>
                    <TextBlock Text="Search clipboard..."
                               Foreground="{StaticResource Overlay0Brush}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Visibility="{Binding SearchText.Length, Converter={StaticResource BoolToVis}, ConverterParameter=inverse}"
                               IsHitTestVisible="False"
                               x:Name="Placeholder"/>
                    <TextBox x:Name="SearchBox"
                             Background="Transparent"
                             Foreground="{StaticResource TextBrush}"
                             CaretBrush="{StaticResource TextBrush}"
                             BorderThickness="0"
                             FontSize="14"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" Padding="4,6,4,2">
                <TextBlock Foreground="{StaticResource Overlay0Brush}" FontSize="11">
                    <Run Text="↑↓"/><Run Text=" Navigate  " Foreground="{StaticResource Surface2Brush}"/>
                    <Run Text="⏎"/><Run Text=" Paste  " Foreground="{StaticResource Surface2Brush}"/>
                    <Run Text="⇧⏎"/><Run Text=" Plain  " Foreground="{StaticResource Surface2Brush}"/>
                    <Run Text="Esc"/><Run Text=" Close" Foreground="{StaticResource Surface2Brush}"/>
                </TextBlock>
            </Border>

            <!-- Item list -->
            <ListBox x:Name="ItemList"
                     ItemsSource="{Binding FilteredItems}"
                     SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     Focusable="False">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Margin" Value="0,1"/>
                        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="4">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource Surface0Brush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background"
                                                    Value="{StaticResource Surface0Brush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ClipboardItemViewModel}">
                        <Grid MinHeight="28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon for text items -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding FormatIcon}"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsTextItem, Converter={StaticResource BoolToVis}}"/>

                            <!-- Thumbnail for image items -->
                            <Image Grid.Column="0"
                                   Source="{Binding Thumbnail}"
                                   Width="72" Height="72"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsImageItem, Converter={StaticResource BoolToVis}}">
                                <Image.ToolTip>
                                    <ToolTip>
                                        <Image Source="{Binding PlacementTarget.DataContext.FullImage, RelativeSource={RelativeSource AncestorType=ToolTip}}"
                                               MaxWidth="300" MaxHeight="300"
                                               Stretch="Uniform"/>
                                    </ToolTip>
                                </Image.ToolTip>
                            </Image>

                            <!-- Preview text -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayText}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="38"
                                       Margin="4,0"
                                       VerticalAlignment="Center"/>

                            <!-- Relative time -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding RelativeTime}"
                                       Foreground="{StaticResource Overlay0Brush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="4,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
