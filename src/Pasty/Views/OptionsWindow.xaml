<Window x:Class="Pasty.Views.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="360" Height="220"
        WindowStartupLocation="CenterScreen">

    <Border CornerRadius="10"
            Background="{StaticResource BaseBrush}"
            BorderBrush="{StaticResource Surface1Brush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.6" ShadowDepth="3" Color="#000000"/>
        </Border.Effect>

        <DockPanel Margin="20">
            <!-- Title -->
            <TextBlock DockPanel.Dock="Top"
                       Text="Options"
                       Foreground="{StaticResource LavenderBrush}"
                       FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,16"/>

            <!-- Buttons -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="SaveButton" Content="Save" Click="OnSave"
                        Width="80" Height="30" Margin="0,0,8,0"
                        Background="{StaticResource Surface0Brush}"
                        Foreground="{StaticResource TextBrush}"
                        BorderBrush="{StaticResource Surface1Brush}"
                        BorderThickness="1" Cursor="Hand"/>
                <Button x:Name="CancelButton" Content="Cancel" Click="OnCancel"
                        Width="80" Height="30"
                        Background="{StaticResource Surface0Brush}"
                        Foreground="{StaticResource TextBrush}"
                        BorderBrush="{StaticResource Surface1Brush}"
                        BorderThickness="1" Cursor="Hand"/>
            </StackPanel>

            <!-- Settings Grid -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Max Entries -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Max Entries:"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="13" VerticalAlignment="Center"/>
                <TextBox x:Name="MaxEntriesBox" Grid.Row="0" Grid.Column="2"
                         Height="28" FontSize="13"
                         Background="{StaticResource Surface0Brush}"
                         Foreground="{StaticResource TextBrush}"
                         CaretBrush="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource Surface1Brush}"
                         BorderThickness="1" Padding="6,2"/>

                <!-- Hotkey -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Hotkey:"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="13" VerticalAlignment="Center"/>
                <TextBox x:Name="HotkeyBox" Grid.Row="2" Grid.Column="2"
                         Height="28" FontSize="13" IsReadOnly="True"
                         Background="{StaticResource Surface0Brush}"
                         Foreground="{StaticResource TextBrush}"
                         CaretBrush="{StaticResource TextBrush}"
                         BorderBrush="{StaticResource Surface1Brush}"
                         BorderThickness="1" Padding="6,2"
                         Cursor="Hand" Focusable="True"
                         GotFocus="OnHotkeyGotFocus"
                         LostFocus="OnHotkeyLostFocus"
                         PreviewKeyDown="OnHotkeyKeyDown"/>
            </Grid>
        </DockPanel>
    </Border>
</Window>
